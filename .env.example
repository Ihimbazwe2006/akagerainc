# Database Configuration
DB_HOST=your_postgres_host.render.com
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_PORT=5432

# FastAPI Configuration
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# PayPal Configuration (SANDBOX - for testing)
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=YOUR_SANDBOX_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_SANDBOX_CLIENT_SECRET

# PayPal Configuration (PRODUCTION - when ready)
# PAYPAL_ENVIRONMENT=production
# PAYPAL_CLIENT_ID=YOUR_PRODUCTION_CLIENT_ID
# PAYPAL_CLIENT_SECRET=YOUR_PRODUCTION_CLIENT_SECRET

# Stripe Configuration (Optional - for future Card payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# MoMo Configuration (Optional - for Mobile Money)
MOMO_API_URL=https://api.momo.provider.com/charge
MOMO_API_KEY=your_momo_api_key
MOMO_RECEIVER_NUMBER=0795226123

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
# For production:
# FRONTEND_URL=https://akagerainc.onrender.com

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
